---
const year = new Date().getFullYear();
---

<footer class="px-6 py-12 mt-auto" style="border-top: 1px solid var(--border);">
  <div class="max-w-[1080px] mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-sm" style="color: var(--text-faint);">
      &copy; {year} Karim Deraz
    </p>
    <div class="flex items-center gap-5">
      <a
        href="/rss.xml"
        class="text-sm transition-colors"
        style="color: var(--text-faint);"
        aria-label="RSS Feed"
      >
        RSS
      </a>
      <a
        href="https://github.com/karimderaz"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm transition-colors"
        style="color: var(--text-faint);"
      >
        GitHub
      </a>
      <a
        href="https://x.com/karimderaz"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm transition-colors"
        style="color: var(--text-faint);"
      >
        X
      </a>
    </div>
  </div>
</footer>
