---
const pathname = Astro.url.pathname;
const isActive = (path: string) => pathname === path || pathname.startsWith(path + "/");
---

<header
  class="sticky top-0 z-50 px-6 py-4 backdrop-blur-md"
  style="background: color-mix(in srgb, var(--bg) 85%, transparent); border-bottom: 1px solid var(--border);"
>
  <nav class="max-w-[1080px] mx-auto flex items-center justify-between">
    <a href="/" class="mono text-base font-semibold tracking-tight flex items-center gap-1.5" style="color: var(--text);">
      <span style="color: var(--accent);">&gt;_</span>
      <span>logs</span><span style="color: var(--text-faint);">/machine</span>
    </a>
    <div class="flex items-center gap-6">
      <a
        href="/writing"
        class="text-sm font-medium transition-colors"
        style={`color: ${isActive("/writing") ? "var(--accent)" : "var(--text-muted)"};`}
      >
        Writing
      </a>
      <a
        href="/agent-duel"
        class="text-sm font-medium transition-colors"
        style={`color: ${isActive("/agent-duel") ? "var(--accent)" : "var(--text-muted)"};`}
      >
        Agent Duel
      </a>
      <a
        href="/about"
        class="text-sm font-medium transition-colors"
        style={`color: ${isActive("/about") ? "var(--accent)" : "var(--text-muted)"};`}
      >
        About
      </a>
      <button
        id="theme-toggle"
        class="p-2 rounded-lg transition-colors cursor-pointer"
        style="color: var(--text-muted);"
        aria-label="Toggle theme"
      >
        <svg class="w-4 h-4 dark-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg class="w-4 h-4 light-icon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<script>
  function setupThemeToggle() {
    const btn = document.getElementById("theme-toggle");
    if (!btn) return;

    const update = () => {
      const isDark = document.documentElement.getAttribute("data-theme") !== "light";
      btn.querySelector(".dark-icon")?.classList.toggle("hidden", !isDark);
      btn.querySelector(".light-icon")?.classList.toggle("hidden", isDark);
    };

    btn.addEventListener("click", () => {
      const current = document.documentElement.getAttribute("data-theme");
      const next = current === "light" ? "dark" : "light";
      document.documentElement.setAttribute("data-theme", next);
      localStorage.setItem("theme", next);
      update();
    });

    update();
  }

  setupThemeToggle();
  document.addEventListener("astro:after-swap", setupThemeToggle);
</script>
