---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
  index?: number;
}

const { title, description, pubDate, slug, tags = [], index } = Astro.props;

const stamp = pubDate.toISOString().slice(0, 10);
const indexLabel = index !== undefined ? String(index).padStart(3, "0") : null;
---

<a href={`/writing/${slug}`} class="log-entry group">
  <div class="flex items-center gap-3 mono text-xs" style="color: var(--text-faint);">
    {indexLabel && (
      <span style="color: var(--accent);">#{indexLabel}</span>
    )}
    <span>{stamp}</span>
    <span class="flex-1 h-px" style="background: var(--border);"></span>
    <span class="opacity-0 group-hover:opacity-100 transition-opacity" style="color: var(--accent);">
      open &rarr;
    </span>
  </div>

  <h3
    class="mt-3 text-xl md:text-2xl font-semibold leading-snug"
    style="font-family: var(--font-serif); color: var(--text); letter-spacing: -0.015em;"
  >
    {title}
  </h3>

  <p class="mt-2 text-base leading-relaxed" style="color: var(--text-muted);">
    {description}
  </p>

  {tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2 mono text-xs">
      {tags.slice(0, 4).map((tag) => (
        <span style="color: var(--text-faint);">
          <span style="color: var(--accent);">#</span>{tag}
        </span>
      ))}
    </div>
  )}
</a>
