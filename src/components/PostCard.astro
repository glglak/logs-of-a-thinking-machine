---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
}

const { title, description, pubDate, slug, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<article class="group py-8" style="border-bottom: 1px solid var(--border);">
  <a href={`/writing/${slug}`} class="block">
    <time
      datetime={pubDate.toISOString()}
      class="text-sm"
      style="color: var(--text-faint);"
    >
      {formattedDate}
    </time>
    <h3
      class="mt-2 text-xl font-semibold group-hover:translate-x-1 transition-transform"
      style="font-family: var(--font-serif); color: var(--text); letter-spacing: -0.01em;"
    >
      {title}
    </h3>
    <p class="mt-2 text-base leading-relaxed" style="color: var(--text-muted);">
      {description}
    </p>
    {tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {tags.slice(0, 3).map((tag) => (
          <span
            class="text-xs px-2 py-0.5 rounded"
            style="background: var(--surface); color: var(--text-faint);"
          >
            {tag}
          </span>
        ))}
      </div>
    )}
  </a>
</article>
