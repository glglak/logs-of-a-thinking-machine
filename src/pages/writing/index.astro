---
import Base from "@/layouts/Base.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import PostCard from "@/components/PostCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("writing", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Base title="Writing — Logs of a Thinking Machine" description="All posts on software, AI, and the craft of engineering.">
  <Header />
  <main class="flex-1 px-6 py-16 max-w-[720px] mx-auto w-full">
    <h1
      class="text-3xl md:text-4xl font-semibold tracking-tight mb-2"
      style="font-family: var(--font-serif); color: var(--text);"
    >
      Writing
    </h1>
    <p class="mb-12" style="color: var(--text-muted);">
      {posts.length} {posts.length === 1 ? "post" : "posts"} on software, AI, and engineering culture.
    </p>
    <div>
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.id}
          tags={post.data.tags}
        />
      ))}
    </div>
  </main>
  <Footer />
</Base>
