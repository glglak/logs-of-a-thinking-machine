---
import Base from "@/layouts/Base.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import PostCard from "@/components/PostCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("writing", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const total = posts.length;
---

<Base title="Writing — Logs of a Thinking Machine" description="All posts on software, AI, and the craft of engineering.">
  <Header />
  <main class="flex-1 px-6 py-16 max-w-[860px] mx-auto w-full">
    <div class="mono text-sm" style="color: var(--text-faint);">
      <span style="color: var(--accent);">$</span> ls -la ./logs
    </div>
    <h1
      class="mt-4 text-4xl md:text-5xl font-semibold tracking-tight"
      style="font-family: var(--font-serif); color: var(--text); letter-spacing: -0.03em;"
    >
      Writing
    </h1>
    <p class="mt-3 mono text-sm" style="color: var(--text-muted);">
      {total} {total === 1 ? "entry" : "entries"} on software, AI, and engineering culture.
    </p>

    <div class="mt-12 grid gap-4">
      {posts.map((post, i) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.id}
          tags={post.data.tags}
          index={total - i}
        />
      ))}
    </div>
  </main>
  <Footer />
</Base>
