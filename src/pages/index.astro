---
import Base from "@/layouts/Base.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import PostCard from "@/components/PostCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("writing", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = posts.filter((p) => p.data.featured);
const recent = posts.slice(0, 5);
---

<Base title="Logs of a Thinking Machine — Karim Deraz">
  <Header />
  <main class="flex-1">
    <section class="px-6 pt-24 pb-16 max-w-[720px] mx-auto">
      <h1
        class="text-4xl md:text-6xl font-semibold leading-[1.1] tracking-tight"
        style="font-family: var(--font-serif); color: var(--text);"
      >
        Logs of a<br />
        <span style="color: var(--accent);">Thinking Machine</span>
      </h1>
      <p class="mt-6 text-lg md:text-xl leading-relaxed max-w-[55ch]" style="color: var(--text-muted);">
        Notes on software engineering, AI, and the human side of building things.
        Written by <strong style="color: var(--text);">Karim Deraz</strong> —
        a developer who thinks about how we think about code.
      </p>
    </section>

    {featured.length > 0 && (
      <section class="px-6 pb-12 max-w-[720px] mx-auto">
        <h2
          class="text-sm font-medium uppercase tracking-wider mb-6"
          style="color: var(--text-faint);"
        >
          Featured
        </h2>
        <div>
          {featured.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={post.id}
              tags={post.data.tags}
            />
          ))}
        </div>
      </section>
    )}

    <section class="px-6 pb-20 max-w-[720px] mx-auto">
      <div class="flex items-center justify-between mb-6">
        <h2
          class="text-sm font-medium uppercase tracking-wider"
          style="color: var(--text-faint);"
        >
          Recent Writing
        </h2>
        <a
          href="/writing"
          class="text-sm font-medium"
          style="color: var(--accent);"
        >
          View all &rarr;
        </a>
      </div>
      <div>
        {recent.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.id}
            tags={post.data.tags}
          />
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Base>
