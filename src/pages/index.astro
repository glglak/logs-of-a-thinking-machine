---
import Base from "@/layouts/Base.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import PostCard from "@/components/PostCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("writing", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = posts.filter((p) => p.data.featured);
const recent = posts.slice(0, 6);
const total = posts.length;
const latest = posts[0]?.data.pubDate.toISOString().slice(0, 10) ?? "—";
---

<Base title="Logs of a Thinking Machine — Karim Deraz">
  <Header />
  <main class="flex-1">
    <!-- Hero -->
    <section class="px-6 pt-20 md:pt-28 pb-16 max-w-[860px] mx-auto">
      <div class="mono text-sm rise" style="color: var(--text-faint); animation-delay: 0s;">
        <span style="color: var(--accent);">$</span> ./boot --identity
      </div>

      <h1
        class="mt-5 text-5xl md:text-7xl font-semibold leading-[1.02] tracking-tight rise"
        style="font-family: var(--font-serif); color: var(--text); letter-spacing: -0.035em; animation-delay: 0.05s;"
      >
        Logs of a<br />
        <span class="gradient-text cursor-blink">Thinking Machine</span>
      </h1>

      <p
        class="mt-7 text-lg md:text-xl leading-relaxed max-w-[56ch] rise"
        style="color: var(--text-muted); animation-delay: 0.12s;"
      >
        Notes on software engineering, AI, and the human side of building things.
        Written by <strong style="color: var(--text);">Karim Deraz</strong> — a developer
        who thinks about how we think about code.
      </p>

      <!-- Status line -->
      <div
        class="mt-9 flex flex-wrap items-center gap-x-6 gap-y-2 mono text-xs rise"
        style="color: var(--text-faint); animation-delay: 0.18s;"
      >
        <span class="flex items-center gap-2">
          <span class="glow-dot"></span> writing
        </span>
        <span><span style="color: var(--text-muted);">{total}</span> entries logged</span>
        <span>last commit <span style="color: var(--text-muted);">{latest}</span></span>
        <a href="/writing" style="color: var(--accent);">browse all &rarr;</a>
      </div>
    </section>

    <!-- Project highlight: Agent Duel -->
    <section class="px-6 pb-14 max-w-[860px] mx-auto">
      <a href="/agent-duel" class="log-entry block">
        <div class="flex items-center gap-3 mb-2">
          <span class="mono text-xs uppercase tracking-[0.18em]" style="color: var(--accent);">// project</span>
          <span class="mono text-xs" style="color: var(--text-faint);">open source · runs locally</span>
        </div>
        <h3 class="text-xl md:text-2xl font-semibold tracking-tight" style="font-family: var(--font-serif); color: var(--text);">
          Agent Duel
        </h3>
        <p class="mt-2 text-base leading-relaxed" style="color: var(--text-muted);">
          One task. Many AI coding agents. May the best PR win. Run the same coding task through
          multiple agents in your own repo and compare them on real evidence — tests, diffs, cost and time.
        </p>
        <span class="mono text-sm inline-flex items-center gap-1 mt-3" style="color: var(--accent);">
          explore the tool &rarr;
        </span>
      </a>
    </section>

    <!-- Featured -->
    {featured.length > 0 && (
      <section class="px-6 pb-14 max-w-[860px] mx-auto">
        <div class="flex items-center gap-3 mb-6">
          <h2 class="mono text-xs uppercase tracking-[0.2em]" style="color: var(--text-faint);">
            <span style="color: var(--accent);">//</span> featured
          </h2>
          <span class="flex-1 h-px" style="background: var(--border);"></span>
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          {featured.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={post.id}
              tags={post.data.tags}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Recent feed -->
    <section class="px-6 pb-24 max-w-[860px] mx-auto">
      <div class="flex items-center gap-3 mb-6">
        <h2 class="mono text-xs uppercase tracking-[0.2em]" style="color: var(--text-faint);">
          <span style="color: var(--accent);">//</span> recent logs
        </h2>
        <span class="flex-1 h-px" style="background: var(--border);"></span>
        <a href="/writing" class="mono text-xs" style="color: var(--accent);">view all</a>
      </div>
      <div class="grid gap-4">
        {recent.map((post, i) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.id}
            tags={post.data.tags}
            index={total - i}
          />
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Base>
